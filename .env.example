# Mux (upload_to_mux.py)
# https://dashboard.mux.com → Settings → API Keys
MUX_TOKEN_ID=your_token_id
MUX_TOKEN_SECRET=your_token_secret

# Supabase (upload_to_supabase.py)
# Dashboard → Settings → API → service_role key (not anon)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
# Optional: bucket for image uploads in Drive mode (course PDF buckets are fixed per course)
SUPABASE_BUCKET=resources-public

# Google OAuth client JSON from Google Cloud Console
GOOGLE_OAUTH_CLIENT_FILE=client_secret.json
